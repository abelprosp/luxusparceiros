{
  "name": "luxus-parceiros",
  "version": "1.0.0",
  "private": true,
  "description": "Luxus Parceiros - Ecossistema SaaS para gestão de parceiros Luxus Telefonia",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @luxus/api prisma generate",
    "db:migrate": "pnpm --filter @luxus/api prisma migrate dev",
    "db:seed": "pnpm --filter @luxus/api prisma db seed",
    "db:cleanup": "pnpm --filter @luxus/api prisma:cleanup",
    "db:studio": "pnpm --filter @luxus/api prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
