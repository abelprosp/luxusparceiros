generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  PARTNER
  ATTENDANT
  FINANCIAL
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum LineStatus {
  AVAILABLE
  RESERVED
  USED
  BLOCKED
  ACTIVATED
  CANCELLED
}

enum SaleStatus {
  IN_ANALYSIS
  APPROVED
  PENDING
  REJECTED
  ACTIVATED
  CANCELLED
  CONTESTED
  DOCUMENTS_PENDING
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum RequestType {
  NEW_ACTIVATION
  BLOCK
  UNBLOCK
  CANCELLATION
  DELETION
  CHIP_EXCHANGE
  PLAN_CHANGE
  PORTABILITY
  SECOND_COPY
  REGISTRATION_CHANGE
}

enum RequestStatus {
  OPEN
  IN_ANALYSIS
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum TicketCategory {
  FINANCIAL
  SUPPORT
  OPERATOR
  SYSTEM
  REGISTRATION
  COMMISSION
  URGENT
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  PENDING
  RESOLVED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CommissionStatus {
  FORECAST
  APPROVED
  PAID
  CANCELLED
}

enum PaymentMethod {
  PIX
  TED
}

enum DocumentType {
  CPF
  CNPJ
  RG
  SELFIE
  CONTRACT
  SIGNATURE
  LINE_PHOTO
  CHIP_PHOTO
  OTHER
}

enum ContractFormat {
  PRINT
  ZAPSIGN
}

enum NotificationType {
  COMMISSION
  LINE_ACTIVATED
  TICKET_REPLY
  SALE_APPROVED
  SALE_REJECTED
  SALE_CONTESTED
  DOCUMENTS_REQUESTED
  CAMPAIGN
  REQUEST
  SYSTEM
}

enum StockMovementType {
  ENTRY
  EXIT
  TRANSFER
  RESERVE
  ACTIVATION
  WRITE_OFF
}

enum FinancialType {
  REVENUE
  EXPENSE
  TRANSFER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  FINISHED
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  PAY
  EXPORT
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  avatar        String?
  role          UserRole  @default(PARTNER)
  isActive      Boolean   @default(true)
  biometricEnabled Boolean @default(false)
  theme         String    @default("system")
  notificationsEnabled Boolean @default(true)
  partnerId     String?
  partner       Partner?  @relation(fields: [partnerId], references: [id])
  lastLoginAt   DateTime?
  lastLoginIp   String?
  lastLoginDevice String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]
  sessions      Session[]
  permissions   UserPermission[]
  sales         Sale[]         @relation("SaleCreatedBy")
  tickets       Ticket[]       @relation("TicketCreatedBy")
  assignedTickets Ticket[]     @relation("TicketAssignedTo")
  ticketMessages TicketMessage[]
  requests      Request[]      @relation("RequestCreatedBy")
  assignedRequests Request[]   @relation("RequestAssignedTo")
  requestComments RequestComment[]
  notifications Notification[]
  auditLogs     AuditLog[]
  stockMovements StockMovement[]

  @@index([email])
  @@index([partnerId])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?
  userAgent String?
  device    String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  module      String
  createdAt   DateTime @default(now())

  users UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model Partner {
  id                String        @id @default(uuid())
  name              String
  tradeName         String?
  document          String        @unique
  documentType      DocumentType  @default(CNPJ)
  email             String
  phone             String
  status            PartnerStatus @default(ACTIVE)
  commissionRate    Decimal       @default(10) @db.Decimal(5, 2)
  goal              Int           @default(0)
  goalMonth         Int           @default(0)
  address           String?
  city              String?
  state             String?
  zipCode           String?
  bankName          String?
  bankAgency        String?
  bankAccount       String?
  pixKey            String?
  pixKeyType        String?
  logo              String?
  notes             String?
  suspendedAt       DateTime?
  suspendedReason   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  users       User[]
  clients     Client[]
  sales       Sale[]
  lines       Line[]
  simCards    SimCard[]
  commissions Commission[]
  tickets     Ticket[]
  requests    Request[]
  stockMovements StockMovement[]
  commissionRules CommissionRule[]
  branches      Branch[]
  partnerPlans  PartnerPlan[]

  @@index([document])
  @@index([status])
  @@index([state])
  @@map("partners")
}

model Branch {
  id              String       @id @default(uuid())
  name            String
  document        String
  address         String?
  city            String?
  state           String?
  phone           String
  email           String
  status          BranchStatus @default(ACTIVE)
  parentPartnerId String
  parentPartner   Partner      @relation(fields: [parentPartnerId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  clients        Client[]
  sales          Sale[]
  stockMovements StockMovement[]
  requests       Request[]

  @@index([parentPartnerId])
  @@index([document])
  @@index([status])
  @@map("branches")
}

model Client {
  id           String       @id @default(uuid())
  name         String
  document     String
  documentType DocumentType @default(CPF)
  rg           String?
  email        String?
  phone        String
  address      String?
  addressNumber String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  notes        String?
  partnerId    String
  partner      Partner      @relation(fields: [partnerId], references: [id])
  branchId     String?
  branch       Branch?      @relation(fields: [branchId], references: [id])
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  lines     Line[]
  sales     Sale[]
  documents Document[]
  requests  Request[]

  @@index([partnerId])
  @@index([branchId])
  @@index([document])
  @@index([name])
  @@map("clients")
}

model Operator {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logo        String?
  status      Boolean  @default(true)
  apiUrl      String?
  apiKey      String?
  apiConfig   Json?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plans     Plan[]
  lines     Line[]
  simCards  SimCard[]
  sales     Sale[]
  commissionRules CommissionRule[]

  @@map("operators")
}

model Plan {
  id              String         @id @default(uuid())
  name            String
  operatorId      String
  operator        Operator       @relation(fields: [operatorId], references: [id])
  price           Decimal        @db.Decimal(10, 2)
  commission      Decimal        @db.Decimal(5, 2)
  commissionType  CommissionType @default(PERCENTAGE)
  commissionValue Decimal        @db.Decimal(10, 2)
  dataFranchise   String?
  speed           String?
  description     String?
  status          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  lines           Line[]
  sales           Sale[]
  commissionRules CommissionRule[]
  partnerPlans    PartnerPlan[]

  @@index([operatorId])
  @@map("plans")
}

model PartnerPlan {
  id               String   @id @default(uuid())
  partnerId        String
  partner          Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  isActive         Boolean  @default(true)
  customCommission Decimal? @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([partnerId, planId])
  @@index([partnerId])
  @@index([planId])
  @@map("partner_plans")
}

model SimCard {
  id         String     @id @default(uuid())
  iccid      String     @unique
  operatorId String
  operator   Operator   @relation(fields: [operatorId], references: [id])
  partnerId  String?
  partner    Partner?   @relation(fields: [partnerId], references: [id])
  status     LineStatus @default(AVAILABLE)
  batchNumber String?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  line Line?
  sales Sale[]

  @@index([iccid])
  @@index([partnerId])
  @@index([operatorId])
  @@index([status])
  @@map("sim_cards")
}

model Line {
  id         String     @id @default(uuid())
  number     String     @unique
  operatorId String
  operator   Operator   @relation(fields: [operatorId], references: [id])
  planId     String?
  plan       Plan?      @relation(fields: [planId], references: [id])
  simCardId  String?    @unique
  simCard    SimCard?   @relation(fields: [simCardId], references: [id])
  partnerId  String?
  partner    Partner?   @relation(fields: [partnerId], references: [id])
  clientId   String?
  client     Client?    @relation(fields: [clientId], references: [id])
  status     LineStatus @default(AVAILABLE)
  reservedAt DateTime?
  activatedAt DateTime?
  cancelledAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  sales Sale[]

  @@index([number])
  @@index([partnerId])
  @@index([status])
  @@index([operatorId])
  @@map("lines")
}

model Sale {
  id                String     @id @default(uuid())
  protocol          String     @unique
  partnerId         String
  partner           Partner    @relation(fields: [partnerId], references: [id])
  branchId          String?
  branch            Branch?    @relation(fields: [branchId], references: [id])
  clientId          String
  client            Client     @relation(fields: [clientId], references: [id])
  operatorId        String
  operator          Operator   @relation(fields: [operatorId], references: [id])
  planId            String
  plan              Plan       @relation(fields: [planId], references: [id])
  campaignId        String?
  campaign          Campaign?  @relation(fields: [campaignId], references: [id])
  lineId            String?
  line              Line?      @relation(fields: [lineId], references: [id])
  simCardId         String?
  simCard           SimCard?   @relation(fields: [simCardId], references: [id])
  chipIccid         String?
  contractFormat    ContractFormat?
  createdById       String
  createdBy         User       @relation("SaleCreatedBy", fields: [createdById], references: [id])
  status            SaleStatus @default(IN_ANALYSIS)
  value             Decimal    @db.Decimal(10, 2)
  commissionValue   Decimal    @default(0) @db.Decimal(10, 2)
  commissionRate    Decimal    @default(0) @db.Decimal(5, 2)
  isPortability     Boolean    @default(false)
  isVirginChip      Boolean    @default(false)
  portabilityNumber String?
  newNumber         String?
  signature         String?
  approvedAt        DateTime?
  activatedAt       DateTime?
  cancelledAt       DateTime?
  rejectionReason   String?
  contestReason     String?
  requiredDocuments Json?
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  documents  Document[]
  commission Commission?

  @@index([partnerId])
  @@index([branchId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@index([protocol])
  @@map("sales")
}

model Document {
  id         String       @id @default(uuid())
  name       String
  type       DocumentType
  url        String
  mimeType   String
  size       Int
  clientId   String?
  client     Client?      @relation(fields: [clientId], references: [id])
  saleId     String?
  sale       Sale?        @relation(fields: [saleId], references: [id])
  requestId  String?
  request    Request?     @relation(fields: [requestId], references: [id])
  ticketId   String?
  ticket     Ticket?      @relation(fields: [ticketId], references: [id])
  uploadedBy String?
  createdAt  DateTime     @default(now())

  @@index([clientId])
  @@index([saleId])
  @@map("documents")
}

model Commission {
  id          String           @id @default(uuid())
  partnerId   String
  partner     Partner          @relation(fields: [partnerId], references: [id])
  saleId      String           @unique
  sale        Sale             @relation(fields: [saleId], references: [id])
  value       Decimal          @db.Decimal(10, 2)
  percentage  Decimal          @db.Decimal(5, 2)
  status      CommissionStatus @default(FORECAST)
  paymentMethod PaymentMethod?
  paidAt      DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
  @@map("commissions")
}

model CommissionRule {
  id         String   @id @default(uuid())
  name       String
  partnerId  String?
  partner    Partner? @relation(fields: [partnerId], references: [id])
  operatorId String?
  operator   Operator? @relation(fields: [operatorId], references: [id])
  planId     String?
  plan       Plan?    @relation(fields: [planId], references: [id])
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  percentage Decimal  @db.Decimal(5, 2)
  fixedValue Decimal? @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("commission_rules")
}

model Request {
  id           String        @id @default(uuid())
  protocol     String        @unique
  type         RequestType
  status       RequestStatus @default(OPEN)
  partnerId    String
  partner      Partner       @relation(fields: [partnerId], references: [id])
  branchId     String?
  branch       Branch?       @relation(fields: [branchId], references: [id])
  clientId     String?
  client       Client?       @relation(fields: [clientId], references: [id])
  createdById  String
  createdBy    User          @relation("RequestCreatedBy", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?         @relation("RequestAssignedTo", fields: [assignedToId], references: [id])
  description  String
  resolution   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  completedAt  DateTime?

  documents Document[]
  comments  RequestComment[]
  timeline  RequestTimeline[]

  @@index([partnerId])
  @@index([branchId])
  @@index([status])
  @@index([protocol])
  @@map("requests")
}

model RequestComment {
  id        String   @id @default(uuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  isInternal Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([requestId])
  @@map("request_comments")
}

model RequestTimeline {
  id        String   @id @default(uuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  action    String
  fromStatus RequestStatus?
  toStatus  RequestStatus?
  userId    String?
  details   String?
  createdAt DateTime @default(now())

  @@index([requestId])
  @@map("request_timeline")
}

model Ticket {
  id           String         @id @default(uuid())
  protocol     String         @unique
  subject      String
  category     TicketCategory
  status       TicketStatus   @default(NEW)
  priority     TicketPriority @default(MEDIUM)
  partnerId    String?
  partner      Partner?       @relation(fields: [partnerId], references: [id])
  createdById  String
  createdBy    User           @relation("TicketCreatedBy", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?          @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  slaDeadline  DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  messages  TicketMessage[]
  documents Document[]
  timeline  TicketTimeline[]

  @@index([status])
  @@index([partnerId])
  @@index([protocol])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  isInternal Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

model TicketTimeline {
  id        String       @id @default(uuid())
  ticketId  String
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  action    String
  fromStatus TicketStatus?
  toStatus  TicketStatus?
  userId    String?
  details   String?
  createdAt DateTime     @default(now())

  @@index([ticketId])
  @@map("ticket_timeline")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Campaign {
  id          String         @id @default(uuid())
  title       String
  description String?
  banner      String?
  image       String?
  message     String?
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  goal        Int?
  prize       String?
  pushEnabled Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sales           Sale[]
  commissionRules CommissionRule[]

  @@map("campaigns")
}

model StockMovement {
  id         String            @id @default(uuid())
  type       StockMovementType
  partnerId  String?
  partner    Partner?          @relation(fields: [partnerId], references: [id])
  branchId   String?
  branch     Branch?           @relation(fields: [branchId], references: [id])
  operatorId String?
  iccid      String?
  number     String?
  quantity   Int               @default(1)
  notes      String?
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  createdAt  DateTime          @default(now())

  @@index([partnerId])
  @@index([branchId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model FinancialRecord {
  id          String        @id @default(uuid())
  type        FinancialType
  description String
  value       Decimal       @db.Decimal(12, 2)
  partnerId   String?
  category    String?
  reference   String?
  paymentMethod PaymentMethod?
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
  @@index([partnerId])
  @@index([date])
  @@map("financial_records")
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  action    AuditAction
  module    String
  entityId  String?
  entityType String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  device    String?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}
