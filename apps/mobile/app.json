{
  "expo": {
    "name": "Luxus Parceiros",
    "slug": "luxus-parceiros",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "luxusparceiros",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.luxus.parceiros",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use biometria para acessar sua conta Luxus Parceiros com segurança.",
        "NSCameraUsageDescription": "Use a câmera para escanear o código de barras do chip e anexar documentos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B0B"
      },
      "package": "com.luxus.parceiros",
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Use a câmera para escanear o código de barras do chip e anexar documentos."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use biometria para acessar sua conta Luxus Parceiros com segurança."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
