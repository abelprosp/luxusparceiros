# Database
POSTGRES_PASSWORD=luxus-local-only
DATABASE_URL=postgresql://luxus:luxus-local-only@localhost:5432/luxus_parceiros?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=troque-por-uma-chave-aleatoria-com-no-minimo-32-caracteres
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-outra-chave-aleatoria-com-no-minimo-32-caracteres
JWT_REFRESH_EXPIRES_IN=7d

# API
API_PORT=3001
API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8081

# Web
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_WS_URL=http://localhost/events
EXPO_PUBLIC_API_URL=http://SEU-IP-LOCAL:3001
EXPO_PUBLIC_WS_URL=http://SEU-IP-LOCAL:3001/events

# Docker local: cria/atualiza apenas dados demo idempotentes.
# Desative em produção.
RUN_DB_SEED=true

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100
