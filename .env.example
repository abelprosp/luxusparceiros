# Database
DATABASE_URL=postgresql://luxus:luxus123@localhost:5432/luxus_parceiros?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=luxus-jwt-secret-change-in-production-min-32-chars
